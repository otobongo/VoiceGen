# Server-side Gemini key for TTS, prepare-copy, and audit. (Required.)
GEMINI_API_KEY=

# OPTIONAL: activates server-side Firebase auth verification on the /api routes.
# Paste a Firebase service-account JSON (single line) or its base64 encoding.
# Leave empty to keep server verification INACTIVE (client sign-in still works;
# guest mode works). See AUTH_SETUP.md.
FIREBASE_SERVICE_ACCOUNT=
